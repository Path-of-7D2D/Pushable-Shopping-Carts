<?xml version="1.0" encoding="UTF-8" ?>
<configs>

	<append xpath="/entity_classes">
		<entity_class name="vehicleShoppingCart">
			<property name="Class" value="EntityBicycle"/>
			<property name="Tags" value="vehicle"/>
			<property name="Prefab" value="#@modfolder:Resources/shoppingcart.unity3d?WheelbarrowPrefab.prefab"/>
			<property name="PrefabCombined" value="true"/>
			<property name="ModelType" value="Standard"/>
			<property name="SurfaceCategory" value="metal"/>
			<property name="IgnoreTrigger" value="true"/>
			<property name="LootList" value="vehicleShoppingCart"/>
			<property name="IsEnemyEntity" value="false"/>
			<property class="Explosion">
				<property name="ParticleIndex" value="25"/>
				<property name="RadiusBlocks" value="1"/>
				<property name="RadiusEntities" value="1"/>
			</property>
			<property name="RotateToGround" value="true"/>
			<property name="Faction" value="none"/>
		</entity_class>
	</append>

</configs>
